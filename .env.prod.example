# ============================
# StokPro - environment produksi (VPS)
# Copy ke .env lalu sesuaikan:  cp .env.prod.example .env
# ============================

# --- Database (Postgres) ---
POSTGRES_USER=stokpro
POSTGRES_PASSWORD=ganti-password-kuat
POSTGRES_DB=stokpro

# --- Backend ---
# WAJIB: random minimal 32 karakter. Generate: openssl rand -hex 32
JWT_SECRET=ganti-dengan-random-minimal-32-karakter
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Origin frontend buat CORS.
#   - akses via IP/HTTP:   http://IP_VPS
#   - akses via domain:    https://stok.domain.com
CORS_ALLOW_ORIGINS=http://localhost

# Set true HANYA saat pertama kali deploy (bikin data demo + user owner),
# lalu balikin ke false dan `docker compose up -d` ulang.
RUN_SEED=true

# --- Frontend ---
# Biarkan /api/v1 (same-origin lewat Caddy).
VITE_API_BASE_URL=/api/v1

# --- Caddy / domain ---
#   :80               -> HTTP saja, cocok untuk akses lewat IP VPS
#   stok.domain.com   -> HTTPS otomatis (Let's Encrypt), domain harus sudah
#                        diarahkan (A record) ke IP VPS
SITE_ADDRESS=:80
