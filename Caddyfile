# StokPro reverse proxy
# SITE_ADDRESS:
#   - ":80"            -> HTTP saja (cocok buat akses lewat IP VPS)
#   - "stok.domain.com" -> HTTPS otomatis (Let's Encrypt)
{$SITE_ADDRESS::80} {
	encode zstd gzip

	# API + dokumentasi FastAPI -> backend
	@api path /api/* /health /docs /openapi.json
	handle @api {
		reverse_proxy backend:8000
	}

	# Sisanya -> frontend (SPA)
	handle {
		reverse_proxy frontend:80
	}
}
